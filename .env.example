# PolyHermes 开发环境配置文件
# 请复制此文件为 .env 并填写实际值

# 数据库配置
# 数据库地址，格式：主机:端口，localhost:3306 表示本地 MySQL 3306 端口
DB_HOST=localhost:3306
# 数据库用户名，通常为 root
DB_USERNAME=root
# 数据库密码，填写你 MySQL 的 root 用户密码
DB_PASSWORD=your_password_here
# 数据库名称，需要提前在 MySQL 中创建此数据库
DB_NAME=polyhermes

# 后端配置
# 服务器端口号，后端服务监听此端口
SERVER_PORT=8000
# 前端开发服务器端口号，前端页面监听此端口
FRONTEND_PORT=3000
# Spring Profile，开发环境建议 dev，生产环境改为 prod
SPRING_PROFILES_ACTIVE=dev
# JWT 密钥，用于生成和验证 Token，生产环境请使用 openssl rand -hex 64 生成安全的随机字符串
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64
# 管理员重置密码密钥，生产环境请使用 openssl rand -hex 32 生成安全的随机字符串
ADMIN_RESET_PASSWORD_KEY=change-me-in-production-use-openssl-rand-hex-32
# 敏感数据加密密钥，不设置时会回退到 JWT_SECRET，建议显式配置独立密钥
ENCRYPTION_KEY=change-me-in-production-use-openssl-rand-hex-32
# 日志级别，可按需调整
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
# 数据保留清理定时任务（默认每天 03:20 执行）
DATA_RETENTION_CLEANUP_CRON=0 20 3 * * *
# 跟单执行事件保留天数
DATA_RETENTION_COPY_TRADING_EXECUTION_EVENT_DAYS=7
# 回测审计事件保留天数
DATA_RETENTION_BACKTEST_AUDIT_EVENT_DAYS=14
# Trader activity 历史保留天数
DATA_RETENTION_TRADER_ACTIVITY_EVENT_HISTORY_DAYS=3
# 上面 3 个保留天数支持小数，例如 0.4=约9.6小时
# 是否保存 Trader activity 原始 payload（LONGTEXT）。默认 false 防止磁盘暴涨
COPY_TRADING_DISCOVERY_ACTIVITY_HISTORY_STORE_RAW_PAYLOAD=false

# 前端配置
# 后端 API 地址，前端开发服务器访问后端的地址
VITE_API_URL=http://localhost:8000
# WebSocket 地址，前端连接后端 WebSocket 服务的地址
VITE_WS_URL=ws://localhost:8000
# 是否启用系统更新功能，false 为禁用，true 为启用
VITE_ENABLE_SYSTEM_UPDATE=false
